# .gitignore

# Лог-файлы
*.log
logs/
*.log.*

# Виртуальное окружение Python
.env/
venv/
env/
.venv/
.env
*.env

# Файлы базы данных
*.db
*.sqlite3

# Кэш и скомпилированные файлы Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Файлы IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Файлы операционной системы
.DS_Store
Thumbs.db

# Временные файлы
tmp/
temp/
*.tmp

# Отчёты Excel (если генерируются)
reports/
*.xlsx

# Node modules (если фронтенд в том же репозитории)
node_modules/

# Сборка фронтенда
dist/
build/

# Переменные окружения (если есть .env файлы)
*.env.local
*.env.production